extends Node2D

var kind := "light"
var radius := 60.0
var direction := Vector2.RIGHT
var lifetime := 0.18
var max_lifetime := 0.18

func setup(new_kind: String, new_radius: float, new_direction: Vector2) -> void:
	kind = new_kind
	radius = new_radius

	if new_direction.length() > 0.01:
		direction = new_direction.normalized()
	else:
		direction = Vector2.RIGHT

	match kind:
		"light", "light_1", "light_2":
			lifetime = 0.14
		"light_3":
			lifetime = 0.18
		"heavy":
			lifetime = 0.22
		"q":
			lifetime = 0.28
		"ultimate":
			lifetime = 0.42
		"perfect":
			lifetime = 0.24
		"death":
			lifetime = 0.28
		_:
			lifetime = 0.18

	max_lifetime = lifetime
	queue_redraw()

func _process(delta: float) -> void:
	lifetime -= delta

	if lifetime <= 0.0:
		queue_free()

	queue_redraw()

func _draw() -> void:
	var t := clampf(lifetime / max_lifetime, 0.0, 1.0)
	var alpha := t

	match kind:
		"light", "light_1":
			_draw_slash(radius, 0.55, Color(1.0, 0.78, 0.30, alpha), 1.0)
		"light_2":
			_draw_slash(radius, 0.55, Color(1.0, 0.82, 0.36, alpha), -1.0)
		"light_3":
			_draw_slash(radius, 0.95, Color(1.0, 0.88, 0.42, alpha), 1.0)
		"heavy":
			_draw_slash(radius, 1.15, Color(1.0, 0.30, 0.18, alpha), 1.0)
		"q":
			_draw_q_burst(alpha)
		"ultimate":
			_draw_ultimate(alpha)
		"perfect":
			_draw_perfect(alpha)
		"death":
			_draw_death_burst(alpha)

func _draw_slash(r: float, width: float, color: Color, side: float = 1.0) -> void:
	var angle := direction.angle()
	var start_angle := angle - width
	var end_angle := angle + width

	if side < 0.0:
		start_angle = angle + width
		end_angle = angle - width

	draw_arc(Vector2.ZERO, r, start_angle, end_angle, 32, color, 7.0)

	var inner_r := r * 0.62
	draw_arc(
		Vector2.ZERO,
		inner_r,
		start_angle,
		end_angle,
		24,
		color.darkened(0.25),
		3.0
	)

	var tip := Vector2.RIGHT.rotated(angle) * r
	draw_line(Vector2.ZERO, tip, Color(color.r, color.g, color.b, 0.34), 2.0)

	if kind == "light_3" or kind == "heavy":
		draw_line(
			Vector2.RIGHT.rotated(angle - 0.35) * r * 0.35,
			Vector2.RIGHT.rotated(angle + 0.35) * r,
			Color(color.r, color.g, color.b, 0.45),
			4.0
		)

func _draw_q_burst(alpha: float) -> void:
	var color := Color(0.75, 0.92, 1.0, alpha)

	draw_circle(Vector2.ZERO, radius * 0.45, Color(0.35, 0.70, 1.0, 0.12 * alpha))
	draw_arc(Vector2.ZERO, radius, 0.0, TAU, 64, color, 5.0)
	draw_line(-direction * radius * 0.6, direction * radius, color, 5.0)

func _draw_ultimate(alpha: float) -> void:
	draw_circle(Vector2.ZERO, radius, Color(1.0, 0.62, 0.12, 0.12 * alpha))
	draw_arc(Vector2.ZERO, radius, 0.0, TAU, 96, Color(1.0, 0.74, 0.28, alpha), 7.0)
	draw_arc(Vector2.ZERO, radius * 0.62, 0.0, TAU, 96, Color(1.0, 0.92, 0.55, alpha), 3.0)

	for i in range(8):
		var a := TAU * float(i) / 8.0
		var p1 := Vector2.RIGHT.rotated(a) * radius * 0.35
		var p2 := Vector2.RIGHT.rotated(a) * radius

		draw_line(p1, p2, Color(1.0, 0.72, 0.25, alpha), 3.0)

func _draw_perfect(alpha: float) -> void:
	draw_circle(Vector2.ZERO, radius, Color(0.90, 0.95, 1.0, 0.12 * alpha))
	draw_arc(Vector2.ZERO, radius, 0.0, TAU, 64, Color(0.90, 0.95, 1.0, alpha), 5.0)
	draw_arc(Vector2.ZERO, radius * 0.55, 0.0, TAU, 64, Color(0.65, 0.90, 1.0, alpha), 2.0)

func _draw_death_burst(alpha: float) -> void:
	draw_circle(Vector2.ZERO, radius, Color(0.86, 0.22, 0.14, 0.12 * alpha))
	draw_arc(Vector2.ZERO, radius, 0.0, TAU, 48, Color(0.86, 0.22, 0.14, alpha), 4.0)

	for i in range(6):
		var a := TAU * float(i) / 6.0
		var p1 := Vector2.RIGHT.rotated(a) * 8.0
		var p2 := Vector2.RIGHT.rotated(a) * radius

		draw_line(p1, p2, Color(1.0, 0.72, 0.35, alpha), 3.0)
