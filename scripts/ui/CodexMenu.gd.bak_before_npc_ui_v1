func _make_label(node_name: String, text_value: String, pos: Vector2, label_size: Vector2, font_size: int, color: Color) -> Label:
	var label := Label.new()
	label.name = node_name
	label.text = text_value
	label.position = pos
	label.size = label_size
	label.mouse_filter = Control.MOUSE_FILTER_IGNORE
	label.add_theme_font_size_override("font_size", font_size)
	label.add_theme_color_override("font_color", color)
	label.add_theme_color_override("font_shadow_color", Color(0, 0, 0, 0.90))
	label.add_theme_constant_override("shadow_offset_x", 2)
	label.add_theme_constant_override("shadow_offset_y", 2)
	label.vertical_alignment = VERTICAL_ALIGNMENT_CENTER
	return label


func _refresh_known_kinds() -> void:
	known_kinds.clear()

	var game_state := _get_game_state()

	if game_state == null:
		return

	if not _object_has_property(game_state, "enemies_killed_by_kind"):
		return

	var kills: Dictionary = game_state.get("enemies_killed_by_kind")

	for key in kills.keys():
		known_kinds.append(str(key))

	known_kinds.sort()

	selected_index = clampi(selected_index, 0, max(0, known_kinds.size() - 1))


func _refresh() -> void:
	var game_state := _get_game_state()

	if game_state == null:
		return

	var total_kills: int = 0

	if _object_has_property(game_state, "total_enemies_killed"):
		total_kills = int(game_state.get("total_enemies_killed"))

	summary_label.text = "Recorded kills: %d" % total_kills

	if known_kinds.is_empty():
		for row in entry_labels:
			row.text = ""

		detail_label.text = "No enemies recorded.\n\nGo below. Kill something. Return with proof."
		preview_sprite.texture = null
		preview_name_label.text = "No Entry"
		preview_stage_label.text = "Unknown"
		return

	for i in range(entry_labels.size()):
		if i >= known_kinds.size():
			entry_labels[i].text = ""
			continue

		var kind := known_kinds[i]
		var count: int = int(game_state.call("get_enemy_kill_count", kind))
		var display_name: String = str(game_state.call("get_enemy_display_name", kind))
		var stage_name: String = str(game_state.call("get_codex_stage_name", kind))

		var marker := "  "
		if i == selected_index:
			marker = "> "

		entry_labels[i].text = "%s%s  x%d  %s" % [marker, display_name, count, stage_name]

	var selected_kind := known_kinds[selected_index]
	detail_label.text = _get_detail_text(selected_kind)
	_refresh_preview(selected_kind)


func _refresh_preview(enemy_kind: String) -> void:
	var game_state := _get_game_state()

	if game_state == null:
		return

	var display_name: String = str(game_state.call("get_enemy_display_name", enemy_kind))
	var stage_name: String = str(game_state.call("get_codex_stage_name", enemy_kind))

	preview_name_label.text = display_name
	preview_stage_label.text = stage_name

	if enemy_kind == last_preview_kind and not preview_frames.is_empty():
		return

	last_preview_kind = enemy_kind
	preview_frames.clear()
	preview_frame_index = 0
	preview_time = 0.0

	var base_path := _get_kind_asset_base_path(enemy_kind)
	var prefix := enemy_kind

	if base_path == "":
		preview_sprite.texture = null
		return

	for i in range(4):
		var path := "%s/%s_idle_anim_f%d.png" % [base_path, prefix, i]

		if ResourceLoader.exists(path):
			var texture := load(path) as Texture2D

			if texture != null:
				preview_frames.append(texture)

	if preview_frames.is_empty():
		preview_sprite.texture = null
	else:
		preview_sprite.texture = preview_frames[0]


func _update_preview_animation() -> void:
	if preview_frames.is_empty():
		return

	var frame := int(preview_time * 6.0) % preview_frames.size()

	if frame == preview_frame_index:
		return

	preview_frame_index = frame
	preview_sprite.texture = preview_frames[preview_frame_index]


func _get_kind_asset_base_path(enemy_kind: String) -> String:
	match enemy_kind:
		"imp":
			return "res://art/enemies/imp"
		"goblin":
			return "res://art/enemies/goblin"
		"skelet":
			return "res://art/enemies/skelet"
		"chort":
			return "res://art/enemies/chort"
		"masked_orc":
			return "res://art/enemies/masked_orc"
		"big_zombie":
			return "res://art/enemies/big_zombie"
		"ogre":
			return "res://art/enemies/ogre"
		"big_demon":
			return "res://art/bosses/big_demon"
		_:
			return ""


func _get_detail_text(enemy_kind: String) -> String:
	var game_state := _get_game_state()

	if game_state == null:
		return "No Codex state found."

	var display_name: String = str(game_state.call("get_enemy_display_name", enemy_kind))
	var count: int = int(game_state.call("get_enemy_kill_count", enemy_kind))
	var stage: int = int(game_state.call("get_codex_stage", enemy_kind))

	var text := "%s\nKilled: %d\n\n" % [display_name, count]

	if stage <= 0:
		return text + "Unknown. The page is blank."

	if stage >= 1:
		text += "Discovered:\nThe Codex has named this creature. It is no longer merely movement in the dark.\n\n"

	if stage >= 2:
		text += "Behavior:\n%s\n\n" % _get_behavior_note(enemy_kind)

	if stage >= 3:
		text += "Lore:\n%s" % _get_lore_note(enemy_kind)
	else:
		text += "Further study required. Full entry unlocks at 10 kills."

	return text


func _get_behavior_note(enemy_kind: String) -> String:
	match enemy_kind:
		"imp":
			return "Fast lesser thing. It favors sudden pounces and punishes careless distance."
		"goblin":
			return "A malformed wretch with a short cleaving arc. Dodge through or away before the cone closes."
		"skelet":
			return "A bonebound shade. Slower, but its line attack reaches farther than instinct expects."
		"chort":
			return "A heavier fiend. Its burst punishes standing too close for too long."
		"masked_orc":
			return "A brute with a broad cleave. The warning is slow; the hit is not."
		"big_zombie":
			return "A swollen dead mass. Slow, obvious, dangerous if ignored."
		"ogre":
			return "Large enough that patience becomes a weapon against it."
		"big_demon":
			return "A greater thing. Its attack pattern shifts, so memory alone is insufficient."
		_:
			return "Observed behavior remains unstable."


func _get_lore_note(enemy_kind: String) -> String:
	match enemy_kind:
		"imp":
			return "Not from Dante's named catalogue. For now, treat it as a placeholder lesser jailor of the Inferno prototype."
		"goblin":
			return "A temporary shape for malformed lesser sinners. Its final identity will be redesigned later."
		"skelet":
			return "A placeholder for the bonebound dead: bodies that forgot the soul but kept the punishment."
		"chort":
			return "A temporary demon-form used to test elite pressure."
		"masked_orc":
			return "A brute placeholder. Later it may become a named guard, sinner, or infernal office."
		"big_zombie":
			return "A swollen dead placeholder for heavy pressure enemies."
		"ogre":
			return "A large-body placeholder for miniboss pressure."
		"big_demon":
			return "The current boss stand-in. Later bosses should be tied to circles, sins, and named figures."
		_:
			return "The Codex admits uncertainty. This entry is not final."


func _get_game_state() -> Node:
	if has_node("/root/GameState"):
		return get_node("/root/GameState")

	return null


func _object_has_property(object: Object, property_name: String) -> bool:
	if object == null:
		return false

	for property in object.get_property_list():
		if str(property["name"]) == property_name:
			return true

	return false


class CodexPanel:
	extends Control

	func _draw() -> void:
		draw_rect(Rect2(Vector2.ZERO, size), Color(0.025, 0.018, 0.015, 0.96))
		draw_rect(Rect2(Vector2(12, 12), size - Vector2(24, 24)), Color(0.08, 0.045, 0.035, 0.90))
		draw_rect(Rect2(Vector2.ZERO, size), Color("#6b2a1f"), false, 4.0)
		draw_rect(Rect2(Vector2(10, 10), size - Vector2(20, 20)), Color("#c4a98f"), false, 1.0)
		draw_line(Vector2(360, 120), Vector2(360, size.y - 58), Color("#c4a98f"), 1.0)
		draw_line(Vector2(720, 120), Vector2(720, size.y - 58), Color("#c4a98f"), 1.0)


