func _build_hub_collision() -> void:
	_clear_hub_collision()

	hub_collision_root = Node2D.new()
	hub_collision_root.name = "GeneratedHubCollision"
	add_child(hub_collision_root)

	_add_hub_outer_boundary()
	_add_training_room_collision()
	_add_archive_room_collision()
	_add_central_room_collision()
	_add_reliquary_room_collision()
	_add_hell_gate_collision()


func _clear_hub_collision() -> void:
	var existing := get_node_or_null("GeneratedHubCollision")

	if existing != null:
		existing.queue_free()


func _add_hub_collision_rect(rect: Rect2, node_name: String) -> void:
	if hub_collision_root == null:
		return

	var body := StaticBody2D.new()
	body.name = node_name
	body.collision_layer = 1
	body.collision_mask = 1
	body.position = rect.position + rect.size * 0.5

	var shape := CollisionShape2D.new()
	var rectangle := RectangleShape2D.new()
	rectangle.size = rect.size
	shape.shape = rectangle

	body.add_child(shape)
	hub_collision_root.add_child(body)


