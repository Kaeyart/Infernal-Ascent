func _draw_background() -> void:
	draw_rect(Rect2(Vector2.ZERO, Vector2(1280, 720)), Color("#060304"))

	for y in range(0, 720, 32):
		for x in range(0, 1280, 32):
			var checker := int(float(x) / 32.0 + float(y) / 32.0)

			if checker % 2 == 0:
				draw_rect(Rect2(Vector2(x, y), Vector2(32, 32)), Color(1, 1, 1, 0.010))


func _draw_foundation() -> void:
	draw_rect(foundation_rect.grow(24), Color(0, 0, 0, 0.32))
	draw_rect(foundation_rect.grow(8), Color("#100708"))
	draw_rect(foundation_rect, Color("#140b0c"))

	for corridor in corridors:
		draw_rect(corridor.grow(20), Color("#100708"))
		draw_rect(corridor.grow(8), Color("#1a0d0e"))


func _draw_tiled_rooms() -> void:
	for key in rooms.keys():
		var room: Dictionary = rooms[key]
		var rect: Rect2 = room.get("rect", Rect2())
		_draw_floor_rect(rect)

	for corridor in corridors:
		_draw_floor_rect(corridor)


func _draw_floor_rect(rect: Rect2) -> void:
	if floor_textures.is_empty():
		draw_rect(rect, Color("#181012"))
		return

	var start_x := int(rect.position.x)
	var start_y := int(rect.position.y)
	var end_x := int(rect.position.x + rect.size.x)
	var end_y := int(rect.position.y + rect.size.y)

	for y in range(start_y, end_y, int(TILE_SIZE)):
		for x in range(start_x, end_x, int(TILE_SIZE)):
			var index_seed := int((x / TILE_SIZE) * 7 + (y / TILE_SIZE) * 11)
			var texture := floor_textures[index_seed % floor_textures.size()]
			var dest := Rect2(Vector2(x, y), Vector2(TILE_SIZE, TILE_SIZE))
			draw_texture_rect(texture, dest, false)


func _draw_room_identity_overlays() -> void:
	for key in rooms.keys():
		var room: Dictionary = rooms[key]
		var rect: Rect2 = room.get("rect", Rect2())
		var fill: Color = room.get("fill", Color(1, 1, 1, 0.0))
		draw_rect(rect, fill)

	var training_rect: Rect2 = rooms["training"]["rect"]
	_draw_floor_scars(training_rect, Color("#9ed8cd"))

	var smith_rect := Rect2(Vector2(1116, 286), Vector2(94, 128))
	draw_rect(smith_rect, Color(0.28, 0.05, 0.02, 0.18))

	var archive_rect: Rect2 = rooms["archive"]["rect"]
	draw_rect(Rect2(archive_rect.position + Vector2(24, 126), Vector2(archive_rect.size.x - 48, 4)), Color("#6d8ed8"))

	var reliquary_rect: Rect2 = rooms["reliquary"]["rect"]
	draw_arc(reliquary_rect.get_center(), 54.0, 0.0, TAU, 64, Color("#f4d49a"), 2.0)


func _draw_floor_scars(rect: Rect2, color: Color) -> void:
	for i in range(8):
		var x := rect.position.x + 42.0 + float(i % 4) * 62.0
		var y := rect.position.y + 72.0 + float(i / 4) * 86.0
		draw_line(Vector2(x - 16, y), Vector2(x + 18, y + 7), Color(color.r, color.g, color.b, 0.20), 1.0)


func _draw_room_walls() -> void:
	for key in rooms.keys():
		var room: Dictionary = rooms[key]
		var rect: Rect2 = room.get("rect", Rect2())
		var color: Color = room.get("color", Color("#dfaa46"))
		_draw_wall_frame(rect, color)

	for corridor in corridors:
		_draw_corridor_edge(corridor)


func _draw_wall_frame(rect: Rect2, accent: Color) -> void:
	draw_rect(rect.grow(14), Color("#070303"), false, 14.0)
	draw_rect(rect.grow(7), Color("#1a0708"), false, 7.0)
	draw_rect(rect.grow(3), Color("#3a1512"), false, 3.0)
	draw_rect(rect, Color(accent.r, accent.g, accent.b, 0.68), false, 1.0)

	_draw_column_at(rect.position)
	_draw_column_at(rect.position + Vector2(rect.size.x, 0))
	_draw_column_at(rect.position + Vector2(0, rect.size.y))
	_draw_column_at(rect.position + Vector2(rect.size.x, rect.size.y))


func _draw_corridor_edge(rect: Rect2) -> void:
	draw_rect(rect.grow(8), Color("#090404"), false, 8.0)
	draw_rect(rect.grow(3), Color("#3a1512"), false, 3.0)
	draw_rect(rect, Color("#6b2a1f"), false, 1.0)


func _draw_column_at(pos: Vector2) -> void:
	if column_texture == null:
		draw_circle(pos, 8.0, Color("#4a2320"))
		return

	draw_texture_rect(
		column_texture,
		Rect2(pos - Vector2(16, 28), Vector2(32, 32)),
		false
	)


func _draw_room_labels() -> void:
	for key in rooms.keys():
