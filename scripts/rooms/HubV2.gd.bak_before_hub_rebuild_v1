func _ready() -> void:
	_load_textures()
	_cache_player()
	_position_existing_nodes()
	_setup_hell_gate_scene()
	_build_hub_collision()
	set_process(true)
	queue_redraw()

func _process(delta: float) -> void:
	pulse_time += delta

	if player == null or not is_instance_valid(player):
		_cache_player()

	_update_hell_gate_interaction()
	queue_redraw()

func _setup_hell_gate_scene() -> void:
	if hell_gate_instance != null and is_instance_valid(hell_gate_instance):
		return

	hell_gate_instance = HellGateScene.instantiate() as Node2D
	hell_gate_instance.name = "HellGate"
	hell_gate_instance.global_position = hell_gate_position
	hell_gate_instance.z_index = 200
	add_child(hell_gate_instance)

	if hell_gate_instance.has_signal("enter_requested"):
		hell_gate_instance.enter_requested.connect(_on_hell_gate_enter_requested)


func _on_hell_gate_enter_requested() -> void:
	enter_run_requested.emit()

func _setup_asset_hell_gate() -> void:
	if hell_gate_sprite != null and is_instance_valid(hell_gate_sprite):
		return

	if not ResourceLoader.exists(HELL_GATE_OPEN_TEXTURE_PATH):
		push_warning("Missing Hell Gate asset: %s" % HELL_GATE_OPEN_TEXTURE_PATH)
		return

	var texture := load(HELL_GATE_OPEN_TEXTURE_PATH) as Texture2D

	if texture == null:
		push_warning("Hell Gate texture loaded as null.")
		return

	hell_gate_sprite = Sprite2D.new()
	hell_gate_sprite.name = "HellGateAsset"
	hell_gate_sprite.texture = texture
	hell_gate_sprite.centered = true
	hell_gate_sprite.global_position = hell_gate_position
	hell_gate_sprite.z_index = 200
	hell_gate_sprite.scale = Vector2(0.16, 0.16)

	add_child(hell_gate_sprite)

func _cache_player() -> void:
	player = get_node_or_null("Player") as Node2D

	if player == null:
		player = get_tree().get_first_node_in_group("player") as Node2D


func _load_textures() -> void:
	floor_textures.clear()

	for path in FLOOR_TEXTURE_PATHS:
		if ResourceLoader.exists(path):
			var texture := load(path) as Texture2D

			if texture != null:
				floor_textures.append(texture)

	column_texture = _load_texture(COLUMN_TEXTURE_PATH)
	column_wall_texture = _load_texture(COLUMN_WALL_TEXTURE_PATH)
	door_top_texture = _load_texture(DOOR_TOP_TEXTURE_PATH)
	door_left_texture = _load_texture(DOOR_LEFT_TEXTURE_PATH)
	door_right_texture = _load_texture(DOOR_RIGHT_TEXTURE_PATH)
	door_closed_texture = _load_texture(DOOR_CLOSED_TEXTURE_PATH)
	chest_texture = _load_texture(CHEST_TEXTURE_PATH)
	crate_texture = _load_texture(CRATE_TEXTURE_PATH)
	banner_red_texture = _load_texture(BANNER_RED_TEXTURE_PATH)
	banner_blue_texture = _load_texture(BANNER_BLUE_TEXTURE_PATH)
	banner_green_texture = _load_texture(BANNER_GREEN_TEXTURE_PATH)
	banner_yellow_texture = _load_texture(BANNER_YELLOW_TEXTURE_PATH)
	spikes_texture = _load_texture(SPIKES_TEXTURE_PATH)


func _load_texture(path: String) -> Texture2D:
	if not ResourceLoader.exists(path):
		return null

	return load(path) as Texture2D


