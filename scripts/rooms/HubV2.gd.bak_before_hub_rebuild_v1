		var color: Color = room.get("color", Color("#dfaa46"))

		var label_pos := rect.position + Vector2(rect.size.x - 158, 22)

		draw_string(
			ThemeDB.fallback_font,
			label_pos,
			label,
			HORIZONTAL_ALIGNMENT_RIGHT,
			145,
			13,
			color
