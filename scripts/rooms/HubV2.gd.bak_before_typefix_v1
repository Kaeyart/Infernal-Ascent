func _draw_background() -> void:
	draw_rect(Rect2(Vector2(-300, -220), Vector2(2200, 1600)), Color("#050203"))

	for y in range(-192, 1280, 64):
		for x in range(-256, 1900, 64):
			if int((x + y) / 64) % 2 == 0:
				draw_rect(Rect2(Vector2(x, y), Vector2(64, 64)), Color(1, 1, 1, 0.006))


func _draw_foundation_shadow() -> void:
