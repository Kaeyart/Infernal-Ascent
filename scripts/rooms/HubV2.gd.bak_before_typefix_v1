func _draw_wall_frame(rect: Rect2, accent: Color) -> void:
	draw_rect(rect.grow(WALL_THICKNESS), Color(0, 0, 0, 0.42), false, WALL_THICKNESS)
	draw_rect(rect.grow(EDGE_THICKNESS), Color("#1b0b0b"), false, EDGE_THICKNESS)
	draw_rect(rect.grow(4), Color("#41201d"), false, 4.0)
	draw_rect(rect, Color(accent.r, accent.g, accent.b, 0.58), false, 1.0)

	_draw_corner_block(rect.position, accent)
	_draw_corner_block(rect.position + Vector2(rect.size.x, 0), accent)
	_draw_corner_block(rect.position + Vector2(0, rect.size.y), accent)
	_draw_corner_block(rect.position + rect.size, accent)


func _draw_corner_block(pos: Vector2, accent: Color) -> void:
	draw_rect(Rect2(pos - Vector2(15, 15), Vector2(30, 30)), Color("#2e1d1b"))
	draw_rect(Rect2(pos - Vector2(11, 11), Vector2(22, 22)), Color("#5c352b"), false, 2.0)
	draw_circle(pos, 4.0, Color(accent.r, accent.g, accent.b, 0.62))


