func _add_asset_sprite(path: String, pos: Vector2, scale_value: float, node_name: String, z: int) -> Sprite2D:
	if generated_sprite_root == null:
		return null

	var texture := _load_texture(path)

	if texture == null:
		push_warning("Missing generated hub asset: %s" % path)
		return null

	var sprite := Sprite2D.new()
	sprite.name = node_name
	sprite.texture = texture
	sprite.centered = true
	sprite.global_position = pos
	sprite.scale = Vector2(scale_value, scale_value)
	sprite.z_index = z
	generated_sprite_root.add_child(sprite)
	return sprite


func _update_runtime_asset_pulse() -> void:
	if generated_sprite_root == null:
		return

	var pulse := 0.82 + 0.12 * absf(sin(pulse_time * 2.0))

	for child in generated_sprite_root.get_children():
		if not child is Sprite2D:
			continue

		var sprite := child as Sprite2D

		if sprite.name.to_lower().contains("brazier") or sprite.name.to_lower().contains("lamp"):
			sprite.modulate = Color(1.0, pulse, pulse * 0.82, 1.0)
		elif sprite.name.to_lower().contains("hell"):
			sprite.modulate = Color(1.0, 0.92 + 0.06 * pulse, 0.84 + 0.08 * pulse, 1.0)
		else:
			sprite.modulate = Color.WHITE


func _setup_hell_gate_scene() -> void:
	if hell_gate_instance != null and is_instance_valid(hell_gate_instance):
		return

	hell_gate_instance = HellGateScene.instantiate() as Node2D
	hell_gate_instance.name = "HellGate"
	hell_gate_instance.global_position = hell_gate_position
	hell_gate_instance.z_index = 60
	add_child(hell_gate_instance)

	if hell_gate_instance.has_method("set"):
		hell_gate_instance.set("interaction_radius", hell_gate_radius)
		hell_gate_instance.set("sprite_scale", Vector2(0.22, 0.22))
		hell_gate_instance.set("prompt_offset", Vector2(-90, 104))

	if hell_gate_instance.has_signal("enter_requested"):
		hell_gate_instance.enter_requested.connect(_on_hell_gate_enter_requested)


func _on_hell_gate_enter_requested() -> void:
	enter_run_requested.emit()


func _update_hell_gate_interaction() -> void:
	is_near_hell_gate = false

	if player == null:
		return

	is_near_hell_gate = player.global_position.distance_to(hell_gate_position) <= hell_gate_radius

	if is_near_hell_gate and _is_interact_pressed():
		enter_run_requested.emit()


func _is_interact_pressed() -> bool:
	if InputMap.has_action("interact") and Input.is_action_just_pressed("interact"):
		return true

	return Input.is_physical_key_pressed(KEY_E)


