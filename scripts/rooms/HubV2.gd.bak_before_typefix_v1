func _draw_all_floors() -> void:
	for corridor in corridors:
		_draw_floor_rect(corridor, false)

	for room_key in rooms.keys():
		var room: Dictionary = rooms[room_key]
		var rect: Rect2 = room.get("rect", Rect2())
		_draw_floor_rect(rect, false)


func _draw_floor_rect(rect: Rect2, use_accent: bool) -> void:
	var textures := accent_floor_textures if use_accent else floor_textures

	if textures.is_empty():
		draw_rect(rect, Color("#1a1112"))
		return

	var start_x := int(rect.position.x)
	var start_y := int(rect.position.y)
	var end_x := int(rect.position.x + rect.size.x)
	var end_y := int(rect.position.y + rect.size.y)

	for y in range(start_y, end_y, FLOOR_TILE_DRAW_SIZE):
		for x in range(start_x, end_x, FLOOR_TILE_DRAW_SIZE):
			var index_seed := abs(int(float(x) / float(FLOOR_TILE_DRAW_SIZE) * 17.0 + float(y) / float(FLOOR_TILE_DRAW_SIZE) * 31.0))
			var texture := textures[index_seed % textures.size()]
			var dest_size := Vector2(FLOOR_TILE_DRAW_SIZE, FLOOR_TILE_DRAW_SIZE)
			var dest := Rect2(Vector2(x, y), dest_size)
			draw_texture_rect(texture, dest, false)


