func _add_room_collision(room_key: String, gaps: Dictionary) -> void:
	var room: Dictionary = rooms[room_key]
	var rect: Rect2 = room.get("rect", Rect2())
	var wall := WALL_THICKNESS

	_add_segmented_wall("%s_Top" % room_key, Rect2(Vector2(rect.position.x - wall, rect.position.y - wall), Vector2(rect.size.x + wall * 2.0, wall)), gaps.get("top", []), true)
	_add_segmented_wall("%s_Bottom" % room_key, Rect2(Vector2(rect.position.x - wall, rect.position.y + rect.size.y), Vector2(rect.size.x + wall * 2.0, wall)), gaps.get("bottom", []), true)
	_add_segmented_wall("%s_Left" % room_key, Rect2(Vector2(rect.position.x - wall, rect.position.y), Vector2(wall, rect.size.y)), gaps.get("left", []), false)
	_add_segmented_wall("%s_Right" % room_key, Rect2(Vector2(rect.position.x + rect.size.x, rect.position.y), Vector2(wall, rect.size.y)), gaps.get("right", []), false)


func _add_segmented_wall(base_name: String, wall_rect: Rect2, gaps: Array, horizontal: bool) -> void:
	if gaps.is_empty():
		_add_hub_collision_rect(wall_rect, base_name)
		return

	var cursor := 0.0
	var length := wall_rect.size.x if horizontal else wall_rect.size.y
	var segment_index := 0

	for gap in gaps:
		if not gap is Rect2:
			continue

		var gap_rect := gap as Rect2
		var gap_start := gap_rect.position.x if horizontal else gap_rect.position.y
		var gap_length := gap_rect.size.x if horizontal else gap_rect.size.y
		var gap_end := gap_start + gap_length

		if gap_start > cursor:
			var segment_rect := wall_rect

			if horizontal:
				segment_rect.position.x = wall_rect.position.x + cursor
				segment_rect.size.x = gap_start - cursor
			else:
				segment_rect.position.y = wall_rect.position.y + cursor
				segment_rect.size.y = gap_start - cursor

			_add_hub_collision_rect(segment_rect, "%s_%d" % [base_name, segment_index])
			segment_index += 1

		cursor = maxf(cursor, gap_end)

	if cursor < length:
		var segment_rect := wall_rect

		if horizontal:
			segment_rect.position.x = wall_rect.position.x + cursor
			segment_rect.size.x = length - cursor
		else:
			segment_rect.position.y = wall_rect.position.y + cursor
			segment_rect.size.y = length - cursor

		_add_hub_collision_rect(segment_rect, "%s_%d" % [base_name, segment_index])


func _add_corridor_collision(rect: Rect2, vertical: bool) -> void:
	var wall := WALL_THICKNESS

	if vertical:
		_add_hub_collision_rect(Rect2(Vector2(rect.position.x - wall, rect.position.y), Vector2(wall, rect.size.y)), "Corridor_Left")
		_add_hub_collision_rect(Rect2(Vector2(rect.position.x + rect.size.x, rect.position.y), Vector2(wall, rect.size.y)), "Corridor_Right")
	else:
		_add_hub_collision_rect(Rect2(Vector2(rect.position.x, rect.position.y - wall), Vector2(rect.size.x, wall)), "Corridor_Top")
		_add_hub_collision_rect(Rect2(Vector2(rect.position.x, rect.position.y + rect.size.y), Vector2(rect.size.x, wall)), "Corridor_Bottom")


func _add_hub_collision_rect(rect: Rect2, node_name: String) -> void:
	if hub_collision_root == null:
		return

	if rect.size.x <= 0.0 or rect.size.y <= 0.0:
		return

	var body := StaticBody2D.new()
	body.name = node_name
	body.collision_layer = 1
	body.collision_mask = 1
	body.position = rect.position + rect.size * 0.5

	var shape := CollisionShape2D.new()
	var rectangle := RectangleShape2D.new()
	rectangle.size = rect.size
	shape.shape = rectangle

	body.add_child(shape)
	hub_collision_root.add_child(body)
