func _load_textures() -> void:
	floor_textures.clear()
	accent_floor_textures.clear()
	texture_cache.clear()

	var floor_paths := [
		_asset_path("structural/floors/structural_structural_floors_001.png"),
		_asset_path("structural/floors/structural_structural_floors_002.png"),
		_asset_path("structural/floors/structural_structural_floors_003.png"),
		_asset_path("structural/floors/structural_structural_floors_004.png"),
		_asset_path("structural/floors/structural_structural_floors_006.png"),
		_asset_path("structural/floors/structural_structural_floors_013.png"),
		_asset_path("structural/floors/structural_structural_floors_014.png"),
		_asset_path("structural/floors/structural_structural_floors_015.png")
	]

	var accent_paths := [
		_asset_path("structural/floors/structural_structural_floors_008.png"),
		_asset_path("structural/floors/structural_structural_floors_011.png"),
		_asset_path("structural/floors/structural_structural_floors_012.png"),
		_asset_path("structural/floors/structural_structural_floors_019.png"),
		_asset_path("structural/floors/structural_structural_floors_020.png")
	]

	for path in floor_paths:
		var texture := _load_texture(path)

		if texture != null:
			floor_textures.append(texture)

	for path in accent_paths:
		var texture := _load_texture(path)

		if texture != null:
			accent_floor_textures.append(texture)


func _asset_path(local_path: String) -> String:
	return "%s/%s" % [ASSET_ROOT, local_path]


func _load_texture(path: String) -> Texture2D:
	if texture_cache.has(path):
		return texture_cache[path]

	if not ResourceLoader.exists(path):
		texture_cache[path] = null
		return null

	var texture := load(path) as Texture2D
	texture_cache[path] = texture
	return texture


