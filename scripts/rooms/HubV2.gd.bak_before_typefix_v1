func _draw_asset_on_canvas(path: String, center: Vector2, size: Vector2, alpha: float = 1.0) -> void:
	var texture := _load_texture(path)

	if texture == null:
		return

	var previous_modulate := Color(1, 1, 1, alpha)
	draw_texture_rect(texture, Rect2(center - size * 0.5, size), false, previous_modulate)


func _draw_room_labels() -> void:
	for room_key in rooms.keys():
		var room: Dictionary = rooms[room_key]
		var rect: Rect2 = room.get("rect", Rect2())
		var label := str(room.get("label", room_key.to_upper()))
		var subtitle := str(room.get("subtitle", ""))
		var color: Color = room.get("color", Color("#dfaa46"))
		var plaque_width := 220.0
		var plaque_pos := Vector2(rect.get_center().x - plaque_width * 0.5, rect.position.y + 18.0)
		var plaque := Rect2(plaque_pos, Vector2(plaque_width, 42.0))

		draw_rect(plaque, Color(0, 0, 0, 0.50))
		draw_rect(plaque, Color(color.r, color.g, color.b, 0.55), false, 1.5)
		draw_string(ThemeDB.fallback_font, plaque.position + Vector2(0, 18), label, HORIZONTAL_ALIGNMENT_CENTER, plaque.size.x, 14, color.lightened(0.18))

		if subtitle != "":
			draw_string(ThemeDB.fallback_font, plaque.position + Vector2(0, 34), subtitle, HORIZONTAL_ALIGNMENT_CENTER, plaque.size.x, 10, Color("#c4a98f"))


