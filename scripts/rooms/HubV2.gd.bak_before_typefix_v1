func _ready() -> void:
	_load_textures()
	_cache_player()
	_position_existing_nodes()
	_setup_player_camera()
	_setup_runtime_assets()
	_setup_hell_gate_scene()
	_build_hub_collision()
	set_process(true)
	queue_redraw()


func _process(delta: float) -> void:
	pulse_time += delta

	if player == null or not is_instance_valid(player):
		_cache_player()
		_setup_player_camera()

	_update_hell_gate_interaction()
	_update_runtime_asset_pulse()
	queue_redraw()


func _cache_player() -> void:
	player = get_node_or_null("Player") as Node2D

	if player == null:
		player = get_tree().get_first_node_in_group("player") as Node2D


func _setup_player_camera() -> void:
	if player == null:
		return

	var camera := player.get_node_or_null("Camera2D") as Camera2D

	if camera == null:
		return

	camera.make_current()
	camera.limit_left = int(world_bounds.position.x - 80.0)
	camera.limit_top = int(world_bounds.position.y - 80.0)
	camera.limit_right = int(world_bounds.position.x + world_bounds.size.x + 80.0)
	camera.limit_bottom = int(world_bounds.position.y + world_bounds.size.y + 80.0)
	camera.position_smoothing_enabled = true
	camera.position_smoothing_speed = 8.0


