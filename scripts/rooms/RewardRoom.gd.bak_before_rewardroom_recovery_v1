func _load_texture_folders(folder_paths: Array) -> Array[Texture2D]:
	var textures: Array[Texture2D] = []

	for value in folder_paths:
		var folder_path: String = str(value)
		var folder_textures: Array[Texture2D] = _load_texture_folder(folder_path)

		for texture in folder_textures:
			textures.append(texture)

	return textures


func _load_texture_folder(folder_path: String) -> Array[Texture2D]:
	var textures: Array[Texture2D] = []
	var files: Array = []
	var dir := DirAccess.open(folder_path)

	if dir == null:
		return textures

	dir.list_dir_begin()
	var file_name := dir.get_next()

	while file_name != "":
		if not dir.current_is_dir() and file_name.to_lower().ends_with(".png"):
			files.append(file_name)

		file_name = dir.get_next()

	dir.list_dir_end()
	files.sort()

	for value in files:
		var texture_path: String = folder_path + "/" + str(value)

		if ResourceLoader.exists(texture_path):
			var texture := load(texture_path) as Texture2D

			if texture != null:
				textures.append(texture)

	return textures


func _load_first_textures(folder_path: String, max_count: int) -> Array[Texture2D]:
	var all_textures: Array[Texture2D] = _load_texture_folder(folder_path)
	var picked: Array[Texture2D] = []
	var limit_count: int = mini(max_count, all_textures.size())

	for i in range(limit_count):
		picked.append(all_textures[i])

	return picked

func _take_reward() -> void:
	reward_taken_flag = true

	match room_type:
		RunState.ROOM_SHOP:
			_apply_shop_reward()
		RunState.ROOM_FORGE:
			_apply_forge_reward()
		RunState.ROOM_SHRINE:
			_apply_shrine_reward()
		RunState.ROOM_FOUNTAIN:
			_apply_fountain_reward()
		_:
			_apply_shop_reward()

	reward_taken.emit()

	if room_type != RunState.ROOM_FOUNTAIN:
		_spawn_choice_doors()

	queue_redraw()


func _apply_shop_reward() -> void:
	if player and player.has_method("gain_ultimate"):
		player.gain_ultimate(30.0)


func _apply_forge_reward() -> void:
	if player:
		player.armor = minf(player.armor + 10.0, player.max_armor)


func _apply_shrine_reward() -> void:
	if player:
		player.hp = minf(player.hp + 25.0, player.max_hp)

	if player and player.has_method("gain_ultimate"):
		player.gain_ultimate(15.0)


func _apply_fountain_reward() -> void:
	if player:
		player.hp = minf(player.hp + 35.0, player.max_hp)
		player.armor = minf(player.armor + 35.0, player.max_armor)

	if player and player.has_method("gain_ultimate"):
		player.gain_ultimate(100.0)


func _spawn_upgrade_cards() -> void:
	if not upgrade_cards.is_empty():
		return

	var offers: Array[RunUpgradeData] = RunState.generate_upgrade_offers(3)

	if offers.is_empty():
		hint = "No upgrades left — choose your next door"
		reward_taken_flag = true
		_spawn_choice_doors()
		return

	var positions: Array[Vector2] = [
		Vector2(386, 332),
		Vector2(640, 300),
		Vector2(894, 332)
	]

	for i in range(offers.size()):
		var card := UpgradeCardScene.instantiate() as Node2D
		card.global_position = positions[i]
		add_child(card)

		if card.has_method("setup"):
			card.setup(offers[i])

		if card.has_signal("upgrade_selected"):
			card.upgrade_selected.connect(_on_upgrade_card_selected)

		upgrade_cards.append(card)


func _on_upgrade_card_selected(upgrade_data: RunUpgradeData) -> void:
	if reward_taken_flag:
		return

	reward_taken_flag = true
	RunState.apply_upgrade(upgrade_data)

	if player and player.has_method("apply_run_modifiers"):
		player.apply_run_modifiers()

	for card in upgrade_cards:
		if card != null and is_instance_valid(card):
			card.queue_free()

	upgrade_cards.clear()
	reward_taken.emit()
	_spawn_choice_doors()
	queue_redraw()


func _spawn_choice_doors() -> void:
	if not choice_doors.is_empty():
		return

	var offers: Array[String] = RunState.generate_offers_after_clear()

	if offers.is_empty():
		return

	var positions: Array[Vector2] = []

	if offers.size() == 1:
		positions = [Vector2(640, 144)]
	else:
		positions = [
			Vector2(412, 160),
			Vector2(640, 144),
			Vector2(868, 160)
		]

	for i in range(offers.size()):
		var offered_room_type: String = str(offers[i])
		var door := ChoiceDoorScene.instantiate() as Node2D
		door.global_position = positions[i]
		add_child(door)

		if door.has_method("setup"):
			door.setup(offered_room_type)

		if door.has_signal("room_choice_requested"):
			door.room_choice_requested.connect(_on_choice_door_selected)

		choice_doors.append(door)


func _on_choice_door_selected(selected_room_type: String) -> void:
	room_choice_requested.emit(selected_room_type)




func _build_reward_room_collision() -> void:
	_clear_reward_room_collision()
	collision_root = Node2D.new()
	collision_root.name = "RewardRoomCollision"
	add_child(collision_root)

	var thickness := 14.0
	_add_reward_collision(Rect2(Vector2(ROOM_RECT.position.x, ROOM_RECT.position.y - thickness), Vector2(ROOM_RECT.size.x, thickness)), "RewardWallTop")
	_add_reward_collision(Rect2(Vector2(ROOM_RECT.position.x, ROOM_RECT.position.y + ROOM_RECT.size.y), Vector2(ROOM_RECT.size.x, thickness)), "RewardWallBottom")
	_add_reward_collision(Rect2(Vector2(ROOM_RECT.position.x - thickness, ROOM_RECT.position.y), Vector2(thickness, ROOM_RECT.size.y)), "RewardWallLeft")
	_add_reward_collision(Rect2(Vector2(ROOM_RECT.position.x + ROOM_RECT.size.x, ROOM_RECT.position.y), Vector2(thickness, ROOM_RECT.size.y)), "RewardWallRight")

	for solid_rect in _get_reward_room_solid_rects():
		_add_reward_collision(solid_rect, "RewardSolid")


func _clear_reward_room_collision() -> void:
	if collision_root != null and is_instance_valid(collision_root):
		collision_root.queue_free()

	collision_root = null


func _get_reward_room_solid_rects() -> Array[Rect2]:
	var rects: Array[Rect2] = []
	var center: Vector2 = ROOM_RECT.get_center()

	match room_type:
		RunState.ROOM_FORGE:
			rects.append(Rect2(center + Vector2(-250, 70), Vector2(84, 72)))
			rects.append(Rect2(center + Vector2(166, 70), Vector2(84, 72)))
		RunState.ROOM_SHOP:
			rects.append(Rect2(center + Vector2(-284, 92), Vector2(96, 58)))
			rects.append(Rect2(center + Vector2(188, 92), Vector2(96, 58)))
		RunState.ROOM_SHRINE:
			rects.append(Rect2(center + Vector2(-326, -38), Vector2(76, 88)))
			rects.append(Rect2(center + Vector2(250, -38), Vector2(76, 88)))
		RunState.ROOM_FOUNTAIN:
			rects.append(Rect2(center + Vector2(-346, -30), Vector2(78, 98)))
			rects.append(Rect2(center + Vector2(268, -30), Vector2(78, 98)))
		_:
			pass

	return rects


func _add_reward_collision(rect: Rect2, collision_name: String) -> void:
	if collision_root == null:
		return

	var body := StaticBody2D.new()
	body.name = collision_name
	body.position = rect.position + rect.size * 0.5

	var shape := CollisionShape2D.new()
	var rect_shape := RectangleShape2D.new()
	rect_shape.size = rect.size
	shape.shape = rect_shape

	body.add_child(shape)
	collision_root.add_child(body)

func _draw() -> void:
	_draw_room()

	if room_type != RunState.ROOM_UPGRADE:
		_draw_reward()

	_draw_hint()


func _draw_room() -> void:
	draw_rect(Rect2(Vector2.ZERO, Vector2(1280, 720)), Color("#050303"))
	_draw_room_rect(ROOM_RECT)
	_draw_top_threshold()
	_draw_room_identity()
	_draw_room_flavor_scatter()
	_draw_room_header()


func _draw_room_rect(rect: Rect2) -> void:
	draw_rect(rect.grow(26.0), Color(0, 0, 0, 0.72))
	draw_rect(rect.grow(12.0), Color("#100606"))
	draw_rect(rect, Color("#17100f"))
	_draw_tiled_floor(rect)
	draw_rect(rect, Color("#5e3a2f"), false, 4.0)

	for i in range(4):
		var corner_pos: Vector2 = rect.position + Vector2(
			0.0 if i % 2 == 0 else rect.size.x,
			0.0 if i < 2 else rect.size.y
