func _draw_tiled_floor(rect: Rect2) -> void:
	if floor_tiles.is_empty():
		draw_rect(rect, Color("#221417"))
		return

	draw_rect(rect, Color("#18100f"))

	var start_x: int = int(rect.position.x)
	var start_y: int = int(rect.position.y)
	var end_x: int = int(rect.position.x + rect.size.x)
	var end_y: int = int(rect.position.y + rect.size.y)
	var safe_count: int = mini(floor_tiles.size(), 4)

	for y in range(start_y, end_y, FLOOR_DRAW_SIZE):
		for x in range(start_x, end_x, FLOOR_DRAW_SIZE):
			var seed: int = abs(int(float(x) / float(FLOOR_DRAW_SIZE) * 17.0 + float(y) / float(FLOOR_DRAW_SIZE) * 29.0))
			var texture: Texture2D = floor_tiles[seed % safe_count]
			var dest := Rect2(Vector2(x, y), Vector2(FLOOR_DRAW_SIZE, FLOOR_DRAW_SIZE))
			draw_texture_rect(texture, dest, false, Color(0.88, 0.82, 0.76, 0.78))


