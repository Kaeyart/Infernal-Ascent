	var start_y := int(rect.position.y)
	var end_x := int(rect.position.x + rect.size.x)
	var end_y := int(rect.position.y + rect.size.y)

	for y in range(start_y, end_y, 32):
		for x in range(start_x, end_x, 32):
			var index_seed := int((x / 32) * 7 + (y / 32) * 11 + RunState.depth * 3)
			var texture := floor_textures[abs(index_seed) % floor_textures.size()]
			draw_texture_rect(texture, Rect2(Vector2(x, y), Vector2(32, 32)), false)


